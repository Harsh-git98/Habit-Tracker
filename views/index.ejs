<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Habit Tracker</title>
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <main class="container">
      <header class="card header-card">
        <h1>Habit Tracker</h1>
        <p>Minimal black dashboard for tracking daily and weekly streaks.</p>
      </header>

      <% if (notice) { %>
      <section class="alert success"><%= notice %></section>
      <% } %>

      <% if (error) { %>
      <section class="alert error"><%= error %></section>
      <% } %>

      <section class="grid">
        <div class="card">
          <h2>Create User</h2>
          <form method="post" action="/web/users" class="stack">
            <label for="email">Email</label>
            <input id="email" name="email" type="email" placeholder="you@example.com" required />
            <button type="submit">Create User</button>
          </form>
        </div>

        <div class="card">
          <h2>View Filters</h2>
          <form method="get" action="/" class="stack">
            <label for="user_id">User</label>
            <select id="user_id" name="user_id">
              <% if (users.length === 0) { %>
              <option value="">No users yet</option>
              <% } %>

              <% users.forEach((user) => { %>
              <option value="<%= user.id %>" <%= user.id === selectedUserId ? 'selected' : '' %>>
                <%= user.email %> (ID: <%= user.id %>)
              </option>
              <% }) %>
            </select>

            <label for="date">Date</label>
            <input id="date" name="date" type="date" value="<%= date %>" />

            <button type="submit">Load Habits</button>
          </form>
        </div>
      </section>

      <section class="card">
        <h2>Create Habit</h2>
        <form method="post" action="/web/habits" class="stack inline-form">
          <input type="hidden" name="date" value="<%= date %>" />

          <label for="habit_user_id">User</label>
          <select id="habit_user_id" name="user_id" required>
            <% users.forEach((user) => { %>
            <option value="<%= user.id %>" <%= user.id === selectedUserId ? 'selected' : '' %>>
              <%= user.email %>
            </option>
            <% }) %>
          </select>

          <label for="title">Title</label>
          <input id="title" name="title" type="text" placeholder="Workout daily" required />

          <label for="frequency">Frequency</label>
          <select id="frequency" name="frequency">
            <option value="daily">Daily</option>
            <option value="weekly">Weekly</option>
          </select>

          <button type="submit" <%= users.length === 0 ? 'disabled' : '' %>>Create Habit</button>
        </form>
      </section>

      <section class="card">
        <div class="section-title">
          <h2>Habits</h2>
          <span>Date: <%= date %></span>
        </div>

        <% if (users.length === 0) { %>
        <p class="muted">Create a user to start tracking habits.</p>
        <% } else if (habits.length === 0) { %>
        <p class="muted">No habits found for selected user.</p>
        <% } else { %>
        <ul class="habit-list">
          <% habits.forEach((habit) => { %>
          <li class="habit-item">
            <div>
              <h3><%= habit.title %></h3>
              <p>
                <span><%= habit.frequency %></span>
                <span>Streak: <strong><%= habit.streak %></strong></span>
                <span>Status: <%= habit.completed_for_date ? 'Done' : 'Pending' %></span>
              </p>
            </div>

            <form method="post" action="/web/habits/<%= habit.id %>/complete" class="complete-form">
              <input type="hidden" name="user_id" value="<%= selectedUserId %>" />
              <input type="hidden" name="date" value="<%= date %>" />
              <input type="hidden" name="completed_date" value="<%= date %>" />
              <button type="submit" <%= habit.completed_for_date ? 'disabled' : '' %>>
                <%= habit.completed_for_date ? 'Completed' : 'Mark Done' %>
              </button>
            </form>
          </li>
          <% }) %>
        </ul>
        <% } %>
      </section>
    </main>
  </body>
</html>
